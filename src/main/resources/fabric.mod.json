{
  "schemaVersion": 1,
  "id": "bettermeteor",
  "version": "${version}",
  "name": "BetterMeteor",
  "description": "A Meteor Client addon for Minecraft 1.21.11.",
  "authors": [
    "BetterMeteor"
  ],
  "contact": {
    "sources": "https://github.com/bettermeteor/bettermeteor"
  },
  "icon": "assets/bettermeteor/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "com.bettermeteor.addon.BetterMeteorAddon"
    ]
  },
  "mixins": [
    "bettermeteor.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
